# AI Test Agent 后端配置示例
# 复制此文件为 .env 并填写实际值

# ============================================
# 数据库配置
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=ai_test_agent

# ============================================
# 服务器配置
# ============================================
HOST=0.0.0.0
PORT=8000
DEBUG=True

# CORS 配置（逗号分隔多个来源）
CORS_ORIGINS=http://localhost:5175,http://localhost:3000

# ============================================
# LLM 模型配置（可选，优先使用数据库配置）
# ============================================

# OpenAI
OPENAI_API_KEY=sk-xxx

# DeepSeek
DEEPSEEK_API_KEY=sk-xxx

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-xxx

# Google (Gemini)
GOOGLE_API_KEY=xxx

# Alibaba (通义千问)
ALIBABA_API_KEY=xxx

# 百度 (文心一言)
BAIDU_API_KEY=xxx

# Moonshot (Kimi)
MOONSHOT_API_KEY=sk-xxx

# Ollama (本地部署)
# 无需 API Key，只需配置端点
OLLAMA_BASE_URL=http://localhost:11434

# ============================================
# Browser-Use 配置
# ============================================
HEADLESS=false
MAX_STEPS=100
MAX_ACTIONS=10
LLM_USE_VISION=false
DISABLE_SECURITY=false

# 页面探索最大步骤数（一键测试功能）
# 探索单个页面建议 15-20 步
# 探索多个主模块建议 30-40 步
# 深度探索多个模块及其子功能建议 50-80 步
EXPLORE_MAX_STEPS=50

# 是否使用极简探索模式（目标驱动，范围可控，成本优化）
# true: 使用极简提示词，严格遵守用户指定范围，根据范围动态调整步骤数
# false: 使用原版探索（深度优先，全面探索）
USE_SIMPLE_EXPLORE=false

# 浏览器路径（可选，留空则自动检测）
# Windows 示例: C:\Program Files\Google\Chrome\Application\chrome.exe
# macOS 示例: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux 示例: /usr/bin/google-chrome
BROWSER_PATH=

# 是否在启动前关闭已有 Chrome 进程（可选，默认 false）
# 设为 true 可避免 Chrome 用户数据目录冲突
KILL_EXISTING_CHROME=false

# 是否使用手动启动 Chrome 模式（推荐，默认 true）
# 手动启动可以更好地控制 Chrome 进程和 CDP 连接
USE_MANUAL_CHROME=true

# ============================================
# Security Test (OWASP ZAP)
# ============================================
# Example when Docker maps host 19090 -> container 8080
ZAP_API_URL=http://127.0.0.1:19090
ZAP_API_KEY=123456
ZAP_MAX_SCAN_MINUTES=30

# ============================================
# Security Test Tools Paths (可选，留空则从 PATH 查找)
# ============================================
# Nuclei 可执行文件路径
# Windows 示例: E:\GoLang\GoModulesCache\bin\nuclei.exe
# Linux/Mac 示例: /usr/local/bin/nuclei
NUCLEI_PATH=

# Nuclei 模板路径（可选）
# 示例: r:\Code\Python\Python_selenium_test_Agent\Ai_Test_Agent\安全测试源代码\nuclei-templates-main\nuclei-templates-main
NUCLEI_TEMPLATES_PATH=

# SQLMap 路径
SQLMAP_PATH=

# XSStrike 路径
XSSTRIKE_PATH=

# ============================================
# 文件存储配置
# ============================================
SAVE_FOLDER_DIR=./save_floder
BUG_IMG_PATH=./save_floder/bug_img

# ============================================
# 邮件服务配置
# ============================================
# 通过数据库 email_config 表配置
