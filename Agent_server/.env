# LLM API Configuration
LLM_BASE_URL=Your_LLM_API_Base_URL
LLM_API_KEY=Your_LLM_API_Key
LLM_MODEL=Your_LLM_Model
VL_TIMEOUT=180
VL_SCHEMA_DIR=../save_floder/vl_schema

# Database Configuration
DB_HOST=Your_DB_HOST
DB_PORT=3306
DB_USER=root
DB_PASSWORD=Your_DB_Password
DB_NAME=ai_test_agent

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True

# File Paths
SAVE_IMG_DIR=../save_img
SAVE_FOLDER_DIR=../save_floder
VL_ANALYSIS_DIR=../save_img/vl_analysis

# Python Environment
PYTHON_PATH=E:\Interpreter\Python_Conda\envs\PyTorch\python.exe

# Redis Configuration
REDIS_URL=redis://Your_REDIS_URL:6379/2

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# API Test Configuration
API_BASE_URL=http://123.56.3.98:81
API_TOKEN=

# ========== Browser-Use Configuration ==========
# 浏览器启动参数
BROWSER_PATH=
BROWSER_USER_DATA=
BROWSER_DEBUGGING_PORT=9222
BROWSER_DEBUGGING_HOST=localhost
KEEP_BROWSER_OPEN=true
USE_OWN_BROWSER=false
BROWSER_CDP=
HEADLESS=false
DISABLE_SECURITY=false

# 路径配置
SAVE_RECORDING_PATH=./tmp/record_videos
SAVE_TRACE_PATH=./tmp/traces
SAVE_AGENT_HISTORY_PATH=./tmp/agent_history
SAVE_DOWNLOAD_PATH=./tmp/downloads

# Browser-Use 日志级别
BROWSER_USE_LOGGING_LEVEL=info
ANONYMIZED_TELEMETRY=false

# ========== Agent 执行配置 ==========
# LLM Provider (同上面的 LLM 配置，保持一致)
LLM_PROVIDER=alibaba
LLM_TEMPERATURE=0.6
LLM_USE_VISION=true

# Agent 执行限制
MAX_STEPS=100
MAX_ACTIONS=10
MAX_INPUT_TOKENS=128000
TOOL_CALLING_METHOD=auto

# 窗口尺寸
BROWSER_WINDOW_WIDTH=1280
BROWSER_WINDOW_HEIGHT=1100
